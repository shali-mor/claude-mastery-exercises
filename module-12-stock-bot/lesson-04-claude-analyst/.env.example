# ─────────────────────────────────────────────────────────────────────────────
# Stock Bot — required credentials
#
# These are NOT used as actual .env variables — n8n stores credentials in its
# own encrypted store. This file documents what you need to set up.
# ─────────────────────────────────────────────────────────────────────────────

# 1. Anthropic API key
#    n8n path: Settings → Credentials → New → Generic Credential Type → Header Auth
#    Header name:  x-api-key
#    Header value: your key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# 2. Telegram bot token
#    n8n path: Settings → Credentials → New → Telegram API
#    Value: from @BotFather in Telegram — /newbot → copy the token
TELEGRAM_BOT_TOKEN=12345678:ABCdefGHIjklMNO...

# 3. Your Telegram chat ID
#    How to find it: Message @userinfobot in Telegram — it replies with your ID
#    Used in: Send Picks node → Chat ID field
#    For a group: add @userinfobot to the group, it sends the group ID
TELEGRAM_CHAT_ID=123456789
